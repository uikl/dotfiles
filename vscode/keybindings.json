// VSCode keybindings — ported from Zed config
[
  // Docks / panels
  // ctrl+b — sidebar: hidden → show+focus, visible → hide
  {
    "key": "ctrl+b",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.toggleSidebarVisibility",
        "workbench.action.focusSideBar"
      ]
    },
    "when": "!sideBarVisible"
  },
  {
    "key": "ctrl+b",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "sideBarVisible"
  },

  // ctrl+n — auxiliary bar: hidden → show+focus, visible → hide
  {
    "key": "ctrl+n",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.toggleAuxiliaryBar",
        "workbench.action.focusAuxiliaryBar"
      ]
    },
    "when": "!auxiliaryBarVisible"
  },
  {
    "key": "ctrl+n",
    "command": "workbench.action.toggleAuxiliaryBar",
    "when": "auxiliaryBarVisible"
  },
  { "key": "ctrl+n", "command": "-workbench.action.files.newUntitledFile" },

  // ; — toggle stage/unstage of current file.
  // If there are any unstaged changes, stage them (covers both fresh mods and
  // partial-stage state). Only unstage when nothing is unstaged.
  { "key": ";", "command": "git.stage", "when": "editorFocus && git.activeResourceHasUnstagedChanges" },
  { "key": ";", "command": "git.unstage", "when": "editorFocus && git.activeResourceHasStagedChanges && !git.activeResourceHasUnstagedChanges" },

  // ctrl+g — toggle diff view of current file (against HEAD).
  // Open the new view, then close the now-stale tab that the open command
  // left behind, so we stay at one tab instead of two.
  {
    "key": "ctrl+g",
    "command": "runCommands",
    "args": {
      "commands": [
        "git.openChange",
        "workbench.action.previousEditor",
        "workbench.action.closeActiveEditor"
      ]
    },
    "when": "editorFocus && !inDiffEditor"
  },
  {
    "key": "ctrl+g",
    "command": "runCommands",
    "args": {
      "commands": [
        "git.openFile",
        "workbench.action.previousEditor",
        "workbench.action.closeActiveEditor"
      ]
    },
    "when": "inDiffEditor"
  },
  { "key": "ctrl+g", "command": "-workbench.action.gotoLine" },

  // Pane navigation — explicit per-context, so each hop is deterministic
  // (navigate* / focus*Group skip the editor or wrap unpredictably).
  //
  // ctrl+h (left): aux bar → editor → side bar; from terminal → side bar.
  // Only chain the SCM focus when SCM is the active viewlet — otherwise the
  // chain forces a switch away from File Explorer / other active views.
  { "key": "ctrl+h", "command": "workbench.action.focusSideBar", "when": "editorFocus && activeViewlet != 'workbench.view.scm'" },
  {
    "key": "ctrl+h",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.focusSideBar",
        "workbench.scm.action.focusNextResourceGroup"
      ]
    },
    "when": "editorFocus && activeViewlet == 'workbench.view.scm'"
  },
  { "key": "ctrl+h", "command": "workbench.action.focusSideBar", "when": "terminalFocus && activeViewlet != 'workbench.view.scm'" },
  {
    "key": "ctrl+h",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.focusSideBar",
        "workbench.scm.action.focusNextResourceGroup"
      ]
    },
    "when": "terminalFocus && activeViewlet == 'workbench.view.scm'"
  },
  { "key": "ctrl+h", "command": "workbench.action.focusActiveEditorGroup", "when": "auxiliaryBarFocus && !panelMaximized" },
  // When panel is maximized, ctrl+h from aux bar goes to terminal instead of editor.
  // Broader fallback (auxiliaryBarVisible + !other-focus) handles webview-in-aux-bar
  // where auxiliaryBarFocus doesn't fire.
  { "key": "ctrl+h", "command": "workbench.action.terminal.focus", "when": "panelMaximized && (auxiliaryBarFocus || (auxiliaryBarVisible && !editorFocus && !terminalFocus && !panelFocus && !sideBarFocus))" },
  //
  // ctrl+l (right): side bar → editor → aux bar; also from terminal → aux bar.
  // When the panel is maximized, side bar → terminal (editor is hidden).
  { "key": "ctrl+l", "command": "workbench.action.focusActiveEditorGroup", "when": "sideBarFocus && !panelMaximized" },
  { "key": "ctrl+l", "command": "workbench.action.terminal.focus", "when": "sideBarFocus && panelMaximized" },
  { "key": "ctrl+l", "command": "workbench.action.focusAuxiliaryBar", "when": "editorFocus" },
  { "key": "ctrl+l", "command": "workbench.action.focusAuxiliaryBar", "when": "terminalFocus" },
  //
  // ctrl+j (down): editor → panel, and ensure panel is maximized so the
  // terminal feels like a full "view" (with tabs across the top).
  {
    "key": "ctrl+j",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.focusPanel",
        "workbench.action.toggleMaximizedPanel"
      ]
    },
    "when": "editorFocus && !panelMaximized"
  },
  { "key": "ctrl+j", "command": "workbench.action.focusPanel", "when": "editorFocus && panelMaximized" },
  //
  // ctrl+k (up): panel/terminal → editor, restoring the panel to normal size
  {
    "key": "ctrl+k",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.toggleMaximizedPanel",
        "workbench.action.focusActiveEditorGroup"
      ]
    },
    "when": "(panelFocus || terminalFocus) && panelMaximized"
  },
  { "key": "ctrl+k", "command": "workbench.action.focusActiveEditorGroup", "when": "(panelFocus || terminalFocus) && !panelMaximized" },
  //
  // ctrl+j from terminal/panel: close it (toggling off). Un-maximize first if
  // maximized, so reopening starts fresh.
  {
    "key": "ctrl+j",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.toggleMaximizedPanel",
        "workbench.action.closePanel"
      ]
    },
    "when": "(panelFocus || terminalFocus) && panelMaximized"
  },
  { "key": "ctrl+j", "command": "workbench.action.closePanel", "when": "(panelFocus || terminalFocus) && !panelMaximized" },

  // Same navigation from inside Claude Code's webview (where focus is in an iframe and the
  // contexts above don't fire). Blur the Claude input first, then focus the editor / panel.
  {
    "key": "ctrl+h",
    "command": "runCommands",
    "args": { "commands": ["claude-vscode.blur", "workbench.action.focusActiveEditorGroup"] },
    "when": "(activeWebviewPanelId == 'claudeVSCodePanel' || (claude-vscode.sideBarActive && !sideBarFocus && !editorFocus && !panelFocus && !terminalFocus)) && !panelMaximized"
  },
  // Same for Claude webview when panel is maximized → go to terminal.
  // Skip claude-vscode.blur here; blurring Claude releases focus to the editor,
  // which un-maximizes the panel. terminal.focus alone keeps the panel maximized.
  {
    "key": "ctrl+h",
    "command": "workbench.action.terminal.focus",
    "when": "panelMaximized && (activeWebviewPanelId == 'claudeVSCodePanel' || (claude-vscode.sideBarActive && !sideBarFocus && !editorFocus && !panelFocus && !terminalFocus))"
  },
  {
    "key": "ctrl+k",
    "command": "runCommands",
    "args": { "commands": ["claude-vscode.blur", "workbench.action.focusActiveEditorGroup"] },
    "when": "activeWebviewPanelId == 'claudeVSCodePanel' || (claude-vscode.sideBarActive && !sideBarFocus && !editorFocus && !panelFocus && !terminalFocus)"
  },
  {
    "key": "ctrl+j",
    "command": "runCommands",
    "args": { "commands": ["claude-vscode.blur", "workbench.action.focusPanel"] },
    "when": "activeWebviewPanelId == 'claudeVSCodePanel' || (claude-vscode.sideBarActive && !sideBarFocus && !editorFocus && !panelFocus && !terminalFocus)"
  },

  // Tab switching in vim normal mode
  {
    "key": "tab",
    "command": "workbench.action.nextEditorInGroup",
    "when": "editorTextFocus && vim.mode == 'Normal'"
  },
  {
    "key": "shift+tab",
    "command": "workbench.action.previousEditorInGroup",
    "when": "editorTextFocus && vim.mode == 'Normal'"
  },

  // Git: stage/unstage
  {
    "key": "shift+n",
    "command": "git.stage",
    "when": "editorTextFocus && vim.mode == 'Normal' && scmProvider == 'git'"
  },

  // SCM navigation. Stack from top to bottom:
  //   commit input → Changes files → Repositories
  //
  // ctrl+k (up): Repositories → Changes files → commit input
  // ctrl+j (down): commit input → Changes files → Repositories
  //
  // From Repositories up to Changes files (skip past commit input)
  {
    "key": "ctrl+k",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.scm.focus",
        "workbench.scm.action.focusNextResourceGroup"
      ]
    },
    "when": "focusedView == 'workbench.scm.repositories'"
  },
  // From Changes files up to commit input
  {
    "key": "ctrl+k",
    "command": "workbench.scm.action.focusPreviousInput",
    "when": "focusedView == 'workbench.scm' && listFocus"
  },
  // From commit input down to Changes files
  {
    "key": "ctrl+j",
    "command": "workbench.scm.action.focusNextResourceGroup",
    "when": "scmRepository && inputFocus && !listFocus"
  },
  // From Changes files down to Repositories
  {
    "key": "ctrl+j",
    "command": "workbench.scm.repositories.focus",
    "when": "focusedView == 'workbench.scm' && listFocus"
  },

  // Terminal: zoom panel
  {
    "key": "ctrl+m",
    "command": "workbench.action.toggleMaximizedPanel",
    "when": "terminalFocus"
  },

  // Auxiliary (secondary) bar: zoom
  {
    "key": "ctrl+m",
    "command": "workbench.action.toggleMaximizedAuxiliaryBar",
    "when": "auxiliaryBarFocus || (auxiliaryBarVisible && !editorFocus && !terminalFocus && !panelFocus && !sideBarFocus)"
  },

  // Explorer: collapse all folders
  {
    "key": "shift+w",
    "command": "workbench.files.action.collapseExplorerFolders",
    "when": "filesExplorerFocus && !inputFocus"
  },

  // Explorer: Enter opens the file instead of renaming it
  {
    "key": "enter",
    "command": "list.select",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "enter",
    "command": "-renameFile",
    "when": "filesExplorerFocus && foldersViewVisible && !inputFocus"
  },

  // Explorer: shift+r to rename, shift+d to delete
  {
    "key": "shift+r",
    "command": "renameFile",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "shift+d",
    "command": "deleteFile",
    "when": "filesExplorerFocus && !inputFocus"
  }
]
